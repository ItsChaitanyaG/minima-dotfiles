[global]
    monitor = 0
    follow = mouse
    width = 300
    height = 300
    origin = top-right
    offset = 10x10
    scale = 0
    notification_limit = 0
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    transparency = 30
    separator_height = 1
    padding = 8
    horizontal_padding = 10
    text_icon_padding = 0
    frame_width = 2
    frame_color = "#ffffff"
    separator_color = frame
    sort = yes
    idle_threshold = 120
    font = JetBrains Mono Nerd Font 10
    line_height = 0
    markup = full
    format = "%s %p\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 0
    max_icon_size = 64
    sticky_history = yes
    history_length = 20
    corner_radius = 10
    ignore_dbusclose = false
    force_xwayland = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 10

[urgency_normal]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 10

[urgency_critical]
    background = "#000000"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 0
